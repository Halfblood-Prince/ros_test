<?xml version="1.0"?>
<sdf version="1.10">
  <world name="building_slam_world">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>40 32</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>40 32</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.72 0.74 0.72 1</ambient>
            <diffuse>0.72 0.74 0.72 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Perimeter wall enclosing the full environment. -->
    <model name="environment_perimeter_wall">
      <static>true</static>

      <link name="perimeter_north_wall">
        <pose>0 15.85 0.75 0 0 0</pose>
        <collision name="collision"><geometry><box><size>40.0 0.3 1.5</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>40.0 0.3 1.5</size></box></geometry><material><ambient>0.25 0.27 0.28 1</ambient><diffuse>0.25 0.27 0.28 1</diffuse></material></visual>
      </link>
      <link name="perimeter_south_wall">
        <pose>0 -15.85 0.75 0 0 0</pose>
        <collision name="collision"><geometry><box><size>40.0 0.3 1.5</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>40.0 0.3 1.5</size></box></geometry><material><ambient>0.25 0.27 0.28 1</ambient><diffuse>0.25 0.27 0.28 1</diffuse></material></visual>
      </link>
      <link name="perimeter_west_wall">
        <pose>-19.85 0 0.75 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.3 32.0 1.5</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.3 32.0 1.5</size></box></geometry><material><ambient>0.25 0.27 0.28 1</ambient><diffuse>0.25 0.27 0.28 1</diffuse></material></visual>
      </link>
      <link name="perimeter_east_wall">
        <pose>19.85 0 0.75 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.3 32.0 1.5</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.3 32.0 1.5</size></box></geometry><material><ambient>0.25 0.27 0.28 1</ambient><diffuse>0.25 0.27 0.28 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Building-like 2D floor plan for lidar SLAM. Each wall is a static box. -->
    <model name="building_floor_plan">
      <static>true</static>

      <!-- Outer walls -->
      <link name="north_wall_left">
        <pose>-4.5 5 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>5.0 0.2 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>5.0 0.2 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>
      <link name="north_wall_right">
        <pose>4.5 5 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>5.0 0.2 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>5.0 0.2 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>
      <link name="south_wall">
        <pose>2 -5 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>18 0.2 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>18 0.2 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>
      <link name="west_wall">
        <pose>-7 0 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.2 10 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.2 10 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>
      <link name="east_wall">
        <pose>11 0 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.2 10 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.2 10 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>
      <link name="north_extension_west_wall">
        <pose>-2.0 8.0 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.2 6.0 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.2 6.0 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>
      <link name="north_extension_east_wall">
        <pose>2.0 8.0 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.2 6.0 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.2 6.0 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>
      <link name="north_extension_top_wall">
        <pose>0 11 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>4.2 0.2 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>4.2 0.2 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>
      <link name="east_wing_top_wall">
        <pose>9 2.8 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>4.0 0.2 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>4.0 0.2 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>
      <link name="east_wing_bottom_wall">
        <pose>9 -2.8 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>4.0 0.2 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>4.0 0.2 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>

      <!-- Interior rooms and corridors -->
      <link name="left_vertical_room_wall">
        <pose>-3.6 2.2 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.18 3.0 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.18 3.0 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="left_room_bottom_wall">
        <pose>-5.7 -1.2 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>2.3 0.18 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>2.3 0.18 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="center_vertical_wall_upper">
        <pose>0.0 3.2 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.18 2.6 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.18 2.6 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="center_vertical_wall_lower">
        <pose>0.0 -3.6 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.18 1.6 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.18 1.6 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="middle_horizontal_wall_left">
        <pose>-2.7 0.2 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>1.6 0.18 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>1.6 0.18 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="middle_horizontal_wall_right">
        <pose>4.2 0.2 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>2.6 0.18 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>2.6 0.18 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="right_room_wall">
        <pose>3.0 3.4 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.18 2.4 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.18 2.4 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="right_room_bottom_wall">
        <pose>5.2 1.1 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>2.6 0.18 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>2.6 0.18 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="east_wing_divider_top">
        <pose>8.4 1.4 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.18 2.8 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.18 2.8 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="east_wing_divider_bottom">
        <pose>8.4 -1.9 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.18 1.8 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.18 1.8 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="north_extension_room_wall">
        <pose>0 8.3 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>2.0 0.18 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>2.0 0.18 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="bottom_room_wall_left">
        <pose>-4.2 -3.4 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.18 2.8 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.18 2.8 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="bottom_room_wall_right">
        <pose>3.6 -3.6 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.18 2.4 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.18 2.4 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>
      <link name="bottom_corridor_wall">
        <pose>2.4 -2.0 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>2.4 0.18 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>2.4 0.18 1.2</size></box></geometry><material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.42 0.42 0.42 1</diffuse></material></visual>
      </link>

      <!-- Furniture-like obstacles for richer lidar features -->
      <link name="table_block_b">
        <pose>1.8 3.6 0.35 0 0 -0.2</pose>
        <collision name="collision"><geometry><box><size>1.1 0.6 0.7</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>1.1 0.6 0.7</size></box></geometry><material><ambient>0.18 0.45 0.7 1</ambient><diffuse>0.18 0.45 0.7 1</diffuse></material></visual>
      </link>
      <link name="pillar_a">
        <pose>5.2 -2.8 0.6 0 0 0</pose>
        <collision name="collision"><geometry><cylinder><radius>0.35</radius><length>1.2</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.35</radius><length>1.2</length></cylinder></geometry><material><ambient>0.7 0.62 0.2 1</ambient><diffuse>0.7 0.62 0.2 1</diffuse></material></visual>
      </link>
    </model>

    <model name="vehicle_blue" canonical_link="chassis">
      <pose>-5.4 2.8 0.12 0 0 0</pose>

      <link name="chassis">
        <pose relative_to="__model__">0 0 0.38 0 0 0</pose>
        <inertial>
          <mass>4.0</mass>
          <inertia>
            <ixx>0.15</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.35</iyy>
            <iyz>0</iyz>
            <izz>0.45</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <box>
              <size>1.2 0.8 0.35</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>1.2 0.8 0.35</size>
            </box>
          </geometry>
          <material>
            <ambient>0.05 0.18 0.85 1</ambient>
            <diffuse>0.05 0.18 0.85 1</diffuse>
          </material>
        </visual>
        <sensor name="gpu_lidar" type="gpu_lidar">
          <pose>0.45 0 0.32 0 0 0</pose>
          <topic>/scan_raw</topic>
          <update_rate>40</update_rate>
          <ray>
            <scan>
              <horizontal>
                <samples>720</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
              </horizontal>
            </scan>
            <range>
              <min>0.08</min>
              <max>5.0</max>
              <resolution>0.01</resolution>
            </range>
          </ray>
          <always_on>1</always_on>
          <visualize>true</visualize>
        </sensor>
        <sensor name="imu_sensor" type="imu">
          <pose>0 0 0 0 0 0</pose>
          <topic>/imu</topic>
          <update_rate>100</update_rate>
          <always_on>1</always_on>
        </sensor>
      </link>

      <link name="left_wheel">
        <pose relative_to="chassis">-0.35 0.48 -0.14 -1.5707 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.02</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.02</iyy><iyz>0</iyz><izz>0.03</izz>
          </inertia>
        </inertial>
        <collision name="collision"><geometry><cylinder><radius>0.24</radius><length>0.14</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.24</radius><length>0.14</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      </link>

      <link name="right_wheel">
        <pose relative_to="chassis">-0.35 -0.48 -0.14 -1.5707 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.02</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.02</iyy><iyz>0</iyz><izz>0.03</izz>
          </inertia>
        </inertial>
        <collision name="collision"><geometry><cylinder><radius>0.24</radius><length>0.14</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.24</radius><length>0.14</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      </link>

      <link name="caster">
        <pose relative_to="chassis">0.42 0 -0.18 0 0 0</pose>
        <inertial>
          <mass>0.2</mass>
          <inertia>
            <ixx>0.004</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.004</iyy><iyz>0</iyz><izz>0.004</izz>
          </inertia>
        </inertial>
        <collision name="collision"><geometry><sphere><radius>0.12</radius></sphere></geometry></collision>
        <visual name="visual"><geometry><sphere><radius>0.12</radius></sphere></geometry><material><ambient>0.1 0.5 0.1 1</ambient><diffuse>0.1 0.5 0.1 1</diffuse></material></visual>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <pose relative_to="left_wheel"/>
        <parent>chassis</parent>
        <child>left_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="right_wheel_joint" type="revolute">
        <pose relative_to="right_wheel"/>
        <parent>chassis</parent>
        <child>right_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="caster_joint" type="ball">
        <parent>chassis</parent>
        <child>caster</child>
      </joint>

      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.96</wheel_separation>
        <wheel_radius>0.24</wheel_radius>
        <odom_publish_frequency>50</odom_publish_frequency>
        <odom_topic>/odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>chassis</child_frame_id>
        <topic>/cmd_vel</topic>
      </plugin>
    </model>
  </world>
</sdf>
