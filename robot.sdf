<?xml version="1.0"?>
<sdf version="1.10">
  <world name="building_slam_world">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>40 32</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>40 32</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.72 0.74 0.72 1</ambient>
            <diffuse>0.72 0.74 0.72 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Perimeter wall enclosing the full environment. -->
    <model name="environment_perimeter_wall">
      <static>true</static>

      <link name="perimeter_north_wall">
        <pose>0 15.85 0.75 0 0 0</pose>
        <collision name="collision"><geometry><box><size>40.0 0.3 1.5</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>40.0 0.3 1.5</size></box></geometry><material><ambient>0.25 0.27 0.28 1</ambient><diffuse>0.25 0.27 0.28 1</diffuse></material></visual>
      </link>
      <link name="perimeter_south_wall">
        <pose>0 -15.85 0.75 0 0 0</pose>
        <collision name="collision"><geometry><box><size>40.0 0.3 1.5</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>40.0 0.3 1.5</size></box></geometry><material><ambient>0.25 0.27 0.28 1</ambient><diffuse>0.25 0.27 0.28 1</diffuse></material></visual>
      </link>
      <link name="perimeter_west_wall">
        <pose>-19.85 0 0.75 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.3 32.0 1.5</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.3 32.0 1.5</size></box></geometry><material><ambient>0.25 0.27 0.28 1</ambient><diffuse>0.25 0.27 0.28 1</diffuse></material></visual>
      </link>
      <link name="perimeter_east_wall">
        <pose>19.85 0 0.75 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.3 32.0 1.5</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.3 32.0 1.5</size></box></geometry><material><ambient>0.25 0.27 0.28 1</ambient><diffuse>0.25 0.27 0.28 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Dense interior floor plan kept below the floor so only the perimeter bounds the map. -->
    <model name="building_floor_plan">
      <pose>0 0 -100 0 0 0</pose>
      <static>true</static>

      <!-- Outer walls -->
      <link name="north_wall_left">
        <pose>-4.5 5 0.6 0 0 0</pose>
        <collision name="collision"><geometry><box><size>5.0 0.2 1.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>5.0 0.2 1.2</size></box></geometry><material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
